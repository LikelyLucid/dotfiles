/* SwayNC — Wallust workstation theme */

@define-color bg {{background}};
@define-color panel {{color0}};
@define-color fg {{foreground}};
@define-color muted {{color8}};
@define-color accent {{color7}};
@define-color active {{color3}};
@define-color urgent {{color1}};

* {
  font-family: "JetBrains Mono Nerd Font";
  font-size: 13px;
}

notificationwindow,
blankwindow {
  background: transparent;
}

.control-center {
  background: alpha(@bg, 0.96);
  color: @fg;
  border: 1px solid @accent;
  border-radius: 5px;
  padding: 8px;
}

.control-center-list {
  background: transparent;
}

.notification-row {
  background: transparent;
  outline: none;
}

.notification-row .notification-background {
  padding: 4px 2px;
}

.notification-row .notification-background .notification {
  background: alpha(@panel, 0.94);
  color: @fg;
  border: 1px solid alpha(@muted, 0.55);
  border-left: 3px solid @accent;
  border-radius: 5px;
  box-shadow: none;
}

.notification-row .notification-background .notification.low {
  border-left-color: @muted;
}

.notification-row .notification-background .notification.critical {
  border-left-color: @urgent;
}

.notification-row .notification-background .notification .notification-default-action,
.notification-row .notification-background .notification .notification-default-action .notification-content {
  background: transparent;
  color: @fg;
  border-radius: 4px;
}

.notification-row .notification-background .notification .notification-default-action:hover {
  background: alpha(@accent, 0.10);
}

.summary {
  color: @fg;
  font-weight: 700;
}

.body {
  color: alpha(@fg, 0.88);
}

.time {
  color: @muted;
  font-size: 11px;
}

.close-button {
  background: transparent;
  color: @muted;
  border: 1px solid transparent;
  border-radius: 4px;
  min-width: 24px;
  min-height: 24px;
}

.close-button:hover {
  background: alpha(@urgent, 0.22);
  color: @fg;
  border-color: @urgent;
}

.notification-action > button {
  background: alpha(@accent, 0.10);
  color: @fg;
  border: 1px solid alpha(@accent, 0.55);
  border-radius: 4px;
}

.notification-action > button:hover {
  background: @accent;
  color: @bg;
}

.widget-title {
  background: transparent;
  color: @fg;
  border-bottom: 1px solid alpha(@muted, 0.55);
  border-radius: 0;
  padding: 4px 2px 10px;
  margin: 0 4px 6px;
}

.widget-title > label {
  font-size: 15px;
  font-weight: 700;
}

.widget-title > button {
  background: alpha(@accent, 0.12);
  color: @fg;
  border: 1px solid alpha(@accent, 0.55);
  border-radius: 4px;
  padding: 4px 10px;
}

.widget-title > button:hover {
  background: @accent;
  color: @bg;
}

.widget-dnd,
.widget-volume,
.widget-backlight,
.widget-mpris,
.widget-buttons-grid,
.widget-menubar,
.widget-inhibitors {
  background: alpha(@panel, 0.70);
  color: @fg;
  border: 1px solid alpha(@muted, 0.35);
  border-radius: 5px;
  padding: 8px;
  margin: 4px;
}

.widget-notifications {
  background: transparent;
  color: @fg;
  border-radius: 0;
  padding: 0;
  margin: 0 2px;
}

.widget-dnd > switch {
  background: alpha(@muted, 0.28);
  border: 1px solid alpha(@muted, 0.55);
  border-radius: 4px;
}

.widget-dnd > switch:checked {
  background: @active;
  border-color: @active;
}

.widget-dnd > switch slider {
  background: @fg;
  border-radius: 3px;
}

scale trough {
  background: alpha(@muted, 0.28);
  border-radius: 2px;
  min-height: 4px;
}

scale highlight,
progressbar progress {
  background: @active;
  border-radius: 2px;
}
